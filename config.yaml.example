# Job Search Agent Configuration

search:
  # Keywords to search for (combined with OR)
  keywords:
    - software engineer
    - backend developer

  # Location filter (city or country)
  location: ""

  # Remote filter: "fulltime", "partial", or "" for any
  remote: "fulltime"

# Which job boards to scrape
boards:
  - builtin     # BuiltIn (HTML scraping, server-side keyword search)
  - jobicy      # Jobicy (JSON API, server-side tag + industry + geo filter)
  - remoteok    # RemoteOK (JSON API, tag-based + client-side filter)
  - himalayas   # Himalayas.app (JSON API, client-side filter, scans 2000 recent)
  - remotive    # Remotive.com (JSON API, server-side keyword search)
  - themuse     # The Muse (JSON API, client-side filter)
  - underdog    # Underdog.io (JSON API, client-side filter, ~83 total jobs)
  # - wttj      # Welcome to the Jungle (Algolia API, mostly European jobs)
  # - wellfound # Wellfound (blocked by DataDome anti-bot)

# Max results per board
results_per_board: 20

# Enable SQLite storage for deduplication (optional)
storage_enabled: false
db_path: "jobs.db"

# Email notifications (optional)
# SMTP connection settings come from environment variables:
#   JSA_SMTP_HOST     - SMTP server (e.g., smtp.gmail.com)
#   JSA_SMTP_PORT     - SMTP port (e.g., 587)
#   JSA_SMTP_USERNAME - SMTP login username
#   JSA_SMTP_PASSWORD - SMTP login password (Gmail: use App Password)
#   JSA_SMTP_FROM     - sender email address
email:
  enabled: false
  recipients:
    - user@example.com
  subject_prefix: "[Job Search Agent]"
